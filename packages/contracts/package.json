{
  "name": "@trusttrace/contracts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./checks": "./src/checks.ts"
  },
  "scripts": {
    "build": "bun run typecheck",
    "lint": "bun run lint:eslint",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:eslint:fix": "eslint . --fix",
    "lint:fix": "bun run lint:eslint:fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/bun": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-tsdoc": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
