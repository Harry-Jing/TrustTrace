# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules/

# Vite build output
# Vite's default production output is dist/; dist-ssr/ is the conventional SSR output.
dist/
dist-ssr/

# Vite local env files
# Vite recommends keeping *.local files out of git because they may contain secrets.
*.local

# Frontend tool caches
.eslintcache
.vite/
.vite-temp/
.cache/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
