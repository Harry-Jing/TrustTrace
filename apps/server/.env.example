# TrustTrace server
TRUSTTRACE_PORT=8000
# Leave blank to use the default apps/server/data/trusttrace.sqlite path.
TRUSTTRACE_DB_PATH=
TRUSTTRACE_LOG_LEVEL=info

# OpenAI-backed claim analysis, LLM web discovery, source assessment, and result copy
OPENAI_API_KEY=
TRUSTTRACE_OPENAI_MODEL=gpt-5.5
TRUSTTRACE_OPENAI_REASONING_EFFORT=low

# Tavily-backed search_api discovery
TAVILY_API_KEY=
TRUSTTRACE_MAX_CANDIDATE_SOURCES=10
TRUSTTRACE_MAX_EVIDENCE_SOURCES=6
