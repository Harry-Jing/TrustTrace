{
  "name": "@trusttrace/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "lint": "bun run typecheck && bun run lint:eslint",
    "lint:eslint": "eslint . --cache",
    "lint:eslint:fix": "eslint . --fix --cache",
    "lint:fix": "bun run lint:eslint:fix",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "bun run typecheck"
  },
  "dependencies": {
    "@tavily/core": "^0.7.2",
    "@trusttrace/contracts": "workspace:*",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.10.7",
    "openai": "^6.34.0",
    "pino": "^10.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-tsdoc": "^0.5.2",
    "typescript": "catalog:",
    "typescript-eslint": "^8.59.1"
  }
}
