{
  "name": "trusttrace",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:server": "bun run --cwd apps/server dev",
    "build": "bun run build:contracts && bun run build:web && bun run build:server",
    "build:web": "bun run --cwd apps/web build",
    "build:server": "bun run --cwd apps/server build",
    "check": "bun run format:check && bun run lint && bun run test && bun run build",
    "prepare": "lefthook install",
    "commitlint": "commitlint",
    "format": "prettier --write --experimental-cli .",
    "format:check": "prettier --check --experimental-cli .",
    "lint": "bun run lint:contracts && bun run lint:web && bun run lint:server",
    "lint:web": "bun run --cwd apps/web lint",
    "lint:server": "bun run --cwd apps/server lint",
    "lint:fix": "bun run lint:fix:web",
    "lint:fix:web": "bun run --cwd apps/web lint:fix",
    "test": "bun run test:web && bun run test:server",
    "test:web": "bun run --cwd apps/web test",
    "test:server": "bun run --cwd apps/server test",
    "test:watch": "bun run --cwd apps/web test:watch",
    "typecheck": "bun run typecheck:contracts && bun run typecheck:web && bun run typecheck:server",
    "typecheck:web": "bun run --cwd apps/web typecheck",
    "typecheck:server": "bun run --cwd apps/server typecheck",
    "build:contracts": "bun run --cwd packages/contracts build",
    "lint:contracts": "bun run --cwd packages/contracts lint",
    "typecheck:contracts": "bun run --cwd packages/contracts typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "lefthook": "^2.1.6",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.2"
  },
  "packageManager": "bun@1.3.13"
}
