{
  "name": "trusttrace",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "bun run --cwd apps/web dev",
    "build": "bun run build:web",
    "build:web": "bun run --cwd apps/web build",
    "check": "bun run format:check && bun run lint && bun run test && bun run build",
    "prepare": "lefthook install",
    "commitlint": "commitlint",
    "format": "bun run format:web",
    "format:web": "bun run --cwd apps/web format",
    "format:check": "bun run format:check:web",
    "format:check:web": "bun run --cwd apps/web format:check",
    "lint": "bun run lint:web",
    "lint:web": "bun run --cwd apps/web lint",
    "lint:fix": "bun run lint:fix:web",
    "lint:fix:web": "bun run --cwd apps/web lint:fix",
    "test": "bun run test:web",
    "test:web": "bun run --cwd apps/web test",
    "test:watch": "bun run --cwd apps/web test:watch",
    "typecheck": "bun run typecheck:web",
    "typecheck:web": "bun run --cwd apps/web typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "lefthook": "^2.1.6"
  },
  "packageManager": "bun@1.3.13"
}
