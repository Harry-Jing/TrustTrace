{
  "name": "trusttrace",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:server": "bun run --cwd apps/server dev",
    "dev:all": "bun run --parallel --filter @trusttrace/web --filter @trusttrace/server dev",
    "start:server": "bun run --cwd apps/server start",
    "build": "bun run --sequential --workspaces build",
    "build:web": "bun run --cwd apps/web build",
    "build:server": "bun run --cwd apps/server build",
    "build:contracts": "bun run --cwd packages/contracts build",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run build",
    "prepare": "lefthook install",
    "commitlint": "commitlint",
    "format": "prettier --write --experimental-cli --no-cache .",
    "format:check": "prettier --check --experimental-cli --no-cache .",
    "lint": "bun run --parallel --workspaces lint",
    "lint:web": "bun run --cwd apps/web lint",
    "lint:server": "bun run --cwd apps/server lint",
    "lint:contracts": "bun run --cwd packages/contracts lint",
    "lint:fix": "bun run lint:fix:web && bun run lint:fix:server && bun run lint:fix:contracts",
    "lint:fix:web": "bun run --cwd apps/web lint:fix",
    "lint:fix:server": "bun run --cwd apps/server lint:fix",
    "lint:fix:contracts": "bun run --cwd packages/contracts lint:fix",
    "test": "bun run --parallel --workspaces test",
    "test:web": "bun run --cwd apps/web test",
    "test:server": "bun run --cwd apps/server test",
    "test:contracts": "bun run --cwd packages/contracts test",
    "test:watch": "bun run test:watch:web",
    "test:watch:web": "bun run --cwd apps/web test:watch",
    "test:watch:server": "bun run --cwd apps/server test:watch",
    "test:watch:contracts": "bun run --cwd packages/contracts test:watch",
    "typecheck": "bun run --parallel --workspaces typecheck",
    "typecheck:web": "bun run --cwd apps/web typecheck",
    "typecheck:server": "bun run --cwd apps/server typecheck",
    "typecheck:contracts": "bun run --cwd packages/contracts typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "lefthook": "^2.1.6",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.13",
  "catalog": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-tsdoc": "^0.5.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.1",
    "zod": "^4.4.1"
  }
}
