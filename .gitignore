# Shared JavaScript workspace dependencies
node_modules/

# Shared coverage output from root quality workflows
coverage/

# TypeScript incremental build metadata
*.tsbuildinfo

# Root-level local environment files
/.env
/.env.*
!/.env.example

# Repository-wide logs
logs/
*.log

# OS and editor noise shared across workspaces
.DS_Store
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Python cache artifacts used by local utility scripts
__pycache__/
*.py[cod]
